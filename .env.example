APP_NAME=EnglishMemory
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8787
APP_TIMEZONE=Asia/Shanghai
ENABLE_SYNC_GENERATION=false

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=english_memory
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

AI_GENERATION_STREAM=english-memory:ai-generation
AI_GENERATION_GROUP=english-memory-workers
AI_GENERATION_CONSUMER_PREFIX=worker
AI_GENERATION_BLOCK_MS=5000
AI_GENERATION_CLAIM_IDLE_MS=60000
AI_GENERATION_COMPENSATION_AGE_SECONDS=120
AI_GENERATION_COMPENSATION_INTERVAL_SECONDS=30

COZE_API_BASE=https://api.coze.cn
COZE_WORKFLOW_ID=7663771858193448987
COZE_ACCESS_TOKEN=
COZE_TIMEOUT=180

AUTH_ACCESS_TOKEN_TTL=900
AUTH_REFRESH_TOKEN_TTL=2592000
AUTH_PASSWORD_RESET_TTL=1800

MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="English Memory"

STORAGE_DRIVER=local
STORAGE_PUBLIC_URL=http://127.0.0.1:8787/storage
